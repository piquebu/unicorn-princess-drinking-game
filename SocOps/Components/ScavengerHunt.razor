@using SocOps.Data

<div class="flex flex-col min-h-full bg-gray-50 cyber-scanline">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 cyber-header">
        <button @onclick="OnReset" class="text-sm px-3 py-1.5 rounded"
                style="color: var(--text-muted); border: 2px solid var(--border-light); border-radius: 0.75rem; font-weight: 700;">
            ← Exit
        </button>
        <h1 class="font-bold cyber-title cyber-glow-cyan" style="font-size: 1.1rem;">� Scavenger Hunt</h1>
        <div class="w-16"></div>
    </header>

    <!-- Progress -->
    <div class="p-3">
        <div class="flex justify-between text-xs mb-2" style="color: var(--text-muted); font-family: 'Pacifico', cursive;">
            <span>Progress</span>
            <span style="color: var(--princess-pink);">@CompletedCount / @Items.Count</span>
        </div>
        <div class="w-full rounded" style="height: 8px; background: var(--bg-surface); border: 2px solid var(--border-light); border-radius: 2rem;">
            <div class="rounded" style="height: 100%; width: @ProgressPercent%; background: linear-gradient(90deg, var(--princess-pink), var(--princess-purple), var(--princess-lavender)); transition: width 0.3s ease; border-radius: 2rem;"></div>
        </div>
    </div>

    @if (CompletedCount == Items.Count)
    {
        <div class="cyber-bingo-banner text-center py-2 font-semibold text-sm" style="font-family: 'Pacifico', cursive;">
            ✨ ALL COMPLETE! ✨
        </div>
    }

    <!-- Checklist -->
    <div class="flex-1 p-3" style="overflow-y: auto;">
        <div class="max-w-md mx-auto space-y-2">
            @for (int i = 0; i < Items.Count; i++)
            {
                var index = i;
                var item = Items[index];
                <button @onclick="() => ToggleItem(index)"
                        class="w-full flex items-center p-3 rounded-lg text-left transition-all duration-150 @(item.IsCompleted ? "cyber-square-marked" : "cyber-square")">
                    <span class="flex items-center justify-center rounded"
                          style="width: 24px; height: 24px; min-width: 24px; margin-right: 12px; border: 2px solid @(item.IsCompleted ? "var(--princess-pink)" : "var(--border-light)"); background: @(item.IsCompleted ? "rgba(236, 72, 153, 0.15)" : "transparent"); border-radius: 0.5rem;">
                        @if (item.IsCompleted)
                        {
                            <span style="color: var(--princess-pink); font-size: 14px;">♥</span>
                        }
                    </span>
                    <span class="text-sm" style="font-weight: 600; @(item.IsCompleted ? "text-decoration: line-through; opacity: 0.6;" : "")">@item.Text</span>
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnReset { get; set; }

    private class HuntItem
    {
        public string Text { get; set; } = "";
        public bool IsCompleted { get; set; }
    }

    private List<HuntItem> Items { get; set; } = new();
    private int CompletedCount => Items.Count(i => i.IsCompleted);
    private int ProgressPercent => Items.Count > 0 ? (int)((double)CompletedCount / Items.Count * 100) : 0;

    protected override void OnInitialized()
    {
        var random = new Random();
        Items = Questions.QuestionsList
            .OrderBy(_ => random.Next())
            .Select(q => new HuntItem { Text = q })
            .ToList();
    }

    private void ToggleItem(int index)
    {
        Items[index].IsCompleted = !Items[index].IsCompleted;
    }
}
