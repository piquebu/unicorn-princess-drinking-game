<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="cyber-card rounded-xl p-6 max-w-xs w-full text-center shadow-xl animate-glitch-in" style="border-color: var(--neon-magenta); box-shadow: var(--glow-magenta);">
        <div class="text-5xl mb-4">⚡</div>
        <h2 class="text-3xl font-bold mb-2 cyber-title cyber-glow-magenta" style="color: var(--neon-magenta);">BINGO!</h2>
        <p class="mb-6" style="color: var(--text-muted);">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="w-full cyber-btn py-3 px-6 rounded-lg">
            Continue
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
