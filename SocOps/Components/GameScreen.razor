@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50 cyber-scanline">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 cyber-header">
        <button
            @onclick="OnReset"
            class="text-sm px-3 py-1.5 rounded" style="color: var(--text-muted); border: 1px solid var(--dark-border);">
            ← Exit
        </button>
        <h1 class="font-bold cyber-title cyber-glow-cyan" style="font-size: 1rem; letter-spacing: 0.15em;">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-sm py-2 px-4" style="color: var(--text-muted); font-weight: 500;">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="cyber-bingo-banner text-center py-2 font-semibold text-sm" style="font-family: 'Orbitron', sans-serif; letter-spacing: 0.1em;">
            ⚡ BINGO! You got a line! ⚡
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
