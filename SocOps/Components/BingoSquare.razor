@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-xs" style="color: var(--princess-pink);">♥</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";

        string stateClasses;
        if (Square.IsFreeSpace)
        {
            stateClasses = "cyber-square-free font-bold text-sm";
        }
        else if (Square.IsMarked)
        {
            stateClasses = IsWinning
                ? "cyber-square-winning"
                : "cyber-square-marked";
        }
        else
        {
            stateClasses = "cyber-square";
        }

        return $"{baseClasses} {stateClasses}";
    }
}
