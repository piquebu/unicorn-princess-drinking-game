<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gray-50 cyber-scanline">
    <div class="text-center max-w-sm animate-fade-slide-up">
        <div style="font-size: 3rem; margin-bottom: 0.5rem;">🦄👑✨</div>
        <h1 class="text-4xl font-bold mb-2 cyber-title cyber-glow-cyan">Soc Ops</h1>
        <p class="text-lg text-gray-500 mb-8" style="font-family: 'Quicksand', sans-serif; font-weight: 700; font-size: 0.9rem; color: var(--princess-purple);">Social Bingo</p>

        <div class="cyber-card rounded-lg p-6 shadow-sm mb-8">
            <h2 class="font-semibold text-gray-800 mb-3 cyber-title" style="font-size: 1rem; color: var(--princess-pink);">How to play</h2>
            <ul class="text-left text-gray-600 text-sm space-y-2" style="font-weight: 600;">
                <li><span style="color: var(--princess-pink);">💖</span> Find people who match the questions</li>
                <li><span style="color: var(--princess-purple);">🔮</span> Tap a square when you find a match</li>
                <li><span style="color: var(--princess-gold);">👑</span> Get 5 in a row to win!</li>
            </ul>
        </div>

        <div class="space-y-2">
            <button
                @onclick="OnStart"
                class="w-full cyber-btn py-4 px-8 rounded-lg text-lg">
                👑 Bingo Grid
            </button>
            <button
                @onclick="OnStartScavenger"
                class="w-full py-3 px-8 rounded-lg text-sm font-semibold transition-all duration-150"
                style="background: rgba(167, 139, 250, 0.1); border: 2px solid var(--princess-purple); color: var(--princess-purple); font-family: 'Pacifico', cursive; border-radius: 2rem;">
                🔮 Scavenger Hunt
            </button>
            <button
                @onclick="OnStartCardDeck"
                class="w-full py-3 px-8 rounded-lg text-sm font-semibold transition-all duration-150"
                style="background: rgba(236, 72, 153, 0.08); border: 2px solid var(--princess-magenta); color: var(--princess-magenta); font-family: 'Pacifico', cursive; border-radius: 2rem;">
                🃏 Card Deck
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }

    [Parameter]
    public EventCallback OnStartScavenger { get; set; }

    [Parameter]
    public EventCallback OnStartCardDeck { get; set; }
}
